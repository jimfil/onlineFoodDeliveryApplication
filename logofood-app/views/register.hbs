{{!-- views/register.hbs — Customer registration --}}
<main class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <h2 class="fw-bold mb-4 text-center">Δημιουργία Λογαριασμού</h2>

                <form action="/register" method="POST" id="registerForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="firstName" class="form-label text-muted small fw-bold">Όνομα</label>
                            <input type="text" id="firstName" name="firstName" class="form-control" 
                                   placeholder="Γιώργος" value="{{userInput.firstName}}" required>
                            {{#if errors.firstName}}<div class="text-danger small mt-1">{{errors.firstName}}</div>{{/if}}
                        </div>

                        <div class="col-md-6">
                            <label for="lastName" class="form-label text-muted small fw-bold">Επώνυμο</label>
                            <input type="text" id="lastName" name="lastName" class="form-control" 
                                   placeholder="Παπαδόπουλος" value="{{userInput.lastName}}" required>
                            {{#if errors.lastName}}<div class="text-danger small mt-1">{{errors.lastName}}</div>{{/if}}
                        </div>

                        <div class="col-md-6">
                            <label for="street" class="form-label text-muted small fw-bold">Οδός</label>
                            <input type="text" id="registerStreet" name="street" class="form-control" 
                                   placeholder="π.χ. Ερμού" value="{{userInput.street}}" required>
                            {{#if errors.street}}<div class="text-danger small mt-1">{{errors.street}}</div>{{/if}}
                        </div>

                        <div class="col-md-3">
                            <label for="streetNumber" class="form-label text-muted small fw-bold">Αριθμός</label>
                            <input type="text" id="registerNumber" name="streetNumber" class="form-control" 
                                   placeholder="π.χ. 12" value="{{userInput.streetNumber}}" required>
                            {{#if errors.streetNumber}}<div class="text-danger small mt-1">{{errors.streetNumber}}</div>{{/if}}
                        </div>

                        <div class="col-md-3">
                            <label for="zipCode" class="form-label text-muted small fw-bold">Τ.Κ.</label>
                            <input type="text" id="registerZip" name="zipCode" class="form-control" 
                                   placeholder="π.χ. 10563" value="{{userInput.zipCode}}">
                            {{#if errors.zipCode}}<div class="text-danger small mt-1">{{errors.zipCode}}</div>{{/if}}
                        </div>

                        <input type="hidden" id="registerLatitude" name="latitude" value="{{userInput.latitude}}">
                        <input type="hidden" id="registerLongitude" name="longitude" value="{{userInput.longitude}}">

                        <div class="col-12">
                            <button type="button" class="btn btn-sm btn-outline-secondary w-100 mb-2 fw-bold" id="toggleRegisterMap">
                                📍 Επιλογή διεύθυνσης στο χάρτη
                            </button>
                            <div id="registerMapContainer" class="d-none mt-3">
                                <div class="mb-3 position-relative">
                                    <label for="registerAddressSearch" class="form-label">Αναζήτηση διεύθυνσης</label>
                                    <input type="text" id="registerAddressSearch" class="form-control" placeholder="π.χ. Ερμού 12" autocomplete="off">
                                    <div id="registerAddressResults" class="list-group mt-2 d-none"></div>
                                </div>
                                <div id="registerMap" class="map-container-lg"></div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label for="email" class="form-label text-muted small fw-bold">Email</label>
                            <input type="email" id="email" name="email" class="form-control" 
                                   placeholder="example@example.com" value="{{userInput.email}}" required>
                            {{#if errors.email}}<div class="text-danger small mt-1">{{errors.email}}</div>{{/if}}
                        </div>

                        <div class="col-12">
                            <label for="password" class="form-label text-muted small fw-bold">Κωδικός Πρόσβασης</label>
                            <div class="input-group">
                                <input type="password" id="password" name="password" class="form-control rounded-start-custom" 
                                       placeholder="Τουλάχιστον 6 χαρακτήρες" required minlength="6">
                                <button class="btn btn-outline-secondary border-secondary-subtle rounded-end-custom" type="button" id="togglePassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            {{#if errors.password}}<div class="text-danger small mt-1">{{errors.password}}</div>{{/if}}
                        </div>

                        <div class="col-12">
                            <label for="confirmPassword" class="form-label text-muted small fw-bold">Επιβεβαίωση Κωδικού</label>
                            <div class="input-group">
                                <input type="password" id="confirmPassword" name="confirmPassword" class="form-control rounded-start-custom"
                                       placeholder="Επαναλάβετε τον κωδικό" required minlength="6">
                                <button class="btn btn-outline-secondary border-secondary-subtle rounded-end-custom" type="button" id="toggleConfirmPassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            {{#if errors.confirmPassword}}<div class="text-danger small mt-1">{{errors.confirmPassword}}</div>{{/if}}
                        </div>

                        <div class="col-12">
                            <label for="contactPhone" class="form-label text-muted small fw-bold">Τηλέφωνο</label>
                            <input type="tel" id="contactPhone" name="contactPhone" class="form-control"
                                   placeholder="69xxxxxxxx" value="{{userInput.contactPhone}}" required
                                   pattern="[0-9]{10}"
                                   title="Πληκτρολογήστε 10 ψηφία. π.χ. 2610323926 ή 6912345678">
                            {{#if errors.contactPhone}}<div class="text-danger small mt-1">{{errors.contactPhone}}</div>{{/if}}
                        </div>

                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-menu btn-lg w-100 fw-bold shadow-sm">Δημιουργία Λογαριασμού</button>
                        </div>

                        <div class="col-12 text-center mt-3">
                            <span class="text-muted small">Έχετε ήδη λογαριασμό? </span>
                            <a href="/login" class="text-decoration-none text-primary small fw-bold">Συνδεθείτε εδώ</a>
                        </div>

                        <div class="col-12 text-center mt-2">
                            <hr class="text-muted opacity-25">
                            <p class="text-muted small mb-1">Θέλετε να συνεργαστείτε μαζί μας;</p>
                            <a href="/register-restaurant" class="text-decoration-none text-primary small fw-bold">Εγγραφή Εστιατορίου</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
