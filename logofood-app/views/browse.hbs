{{!-- views/browse.hbs — Restaurant listing --}}
{{!-- Address Picker Section --}}
<section class="container mb-4 text-center" id="heroSlogan" style="padding-top: 30px; padding-bottom: 10px;">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <h1 class="display-5 fw-bold mb-1"
                style="background: linear-gradient(180deg, #4f0163, #cd03ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent;padding-bottom: 5px;">
                Είτε αλοιφή είτε σως, LogoFood τα έχει όλα
            </h1>
            <p class="text-muted lead">Ανακάλυψε τις καλύτερες γεύσεις της πόλης σου.</p>
        </div>
    </div>
</section>

<section class="container my-4" id="addressPickerSection">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">

            {{#if noAddress}}
            {{!-- No address: inline add form --}}
            <div id="noAddressSection">
                <div class="alert alert-warning mb-3 shadow-sm border-0 rounded-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Δεν έχεις αποθηκευμένη διεύθυνση. Πρόσθεσε μία για να δεις τα εστιατόρια.
                </div>
                <form id="browseNoAddressForm" action="/browse" method="GET">
                    <div class="row g-2 mb-2">
                        <div class="col-md-5">
                            <input type="text" name="street" id="browseStreet" class="form-control"
                                placeholder="Οδός (π.χ. Ερμού)" required>
                        </div>
                        <div class="col-md-2">
                            <input type="text" name="streetNumber" id="browseNumber" class="form-control"
                                placeholder="Αρ." required>
                        </div>
                        <div class="col-md-2">
                            <input type="text" name="zipCode" id="browseZip" class="form-control" placeholder="Τ.Κ.">
                        </div>
                        <input type="hidden" name="latitude" id="browseLatitude">
                        <input type="hidden" name="longitude" id="browseLongitude">
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-menu w-100 fw-bold">Αποθήκευση</button>
                        </div>
                    </div>
                    <div class="col-12">
                        <button type="button" class="btn btn-sm btn-outline-secondary w-100 mb-2 fw-bold"
                            id="toggleBrowseMap">
                            📍 Επιλογή στο χάρτη
                        </button>
                        <div id="browseMapContainer" class="d-none mt-3">
                            <div class="mb-3 position-relative">
                                <label for="browseAddressSearch" class="form-label">Αναζήτηση διεύθυνσης</label>
                                <input type="text" id="browseAddressSearch" class="form-control"
                                    placeholder="π.χ. Ερμού 12" autocomplete="off">
                                <div id="browseAddressResults" class="list-group mt-2 d-none"></div>
                            </div>
                            <div id="browseMap" class="map-container-lg"></div>
                        </div>
                    </div>
                </form>
            </div>
            {{else}}
            {{!-- Address accordion (same style as cart) --}}
            <div id="browseAddressAccordion">
                <div class="accordion" id="browseAccordion">
                    <div class="accordion-item border-0 shadow-sm rounded-4 overflow-hidden">
                        <h2 class="accordion-header">
                            <button class="accordion-button fw-bold bg-white" type="button" data-bs-toggle="collapse"
                                data-bs-target="#browseAddressCollapse">
                                <i class="bi bi-geo-alt-fill me-2 text-primary"></i>
                                {{#if deliveryAddress}}{{deliveryAddress}}{{else}}Επιλογή διεύθυνσης παράδοσης{{/if}}
                            </button>
                        </h2>
                        <div id="browseAddressCollapse" class="accordion-collapse collapse"
                            data-bs-parent="#browseAccordion">
                            <div class="accordion-body p-0">
                                <div class="list-group list-group-flush">
                                    {{#each addresses}}
                                    <a href="/browse?street={{street}}&streetNumber={{street_number}}&zipCode={{zip_code}}{{#if latitude}}&latitude={{latitude}}{{/if}}{{#if longitude}}&longitude={{longitude}}{{/if}}"
                                        class="list-group-item list-group-item-action py-3">
                                        {{street}} {{street_number}}
                                    </a>
                                    {{/each}}

                                    {{#if user}}
                                    {{!-- Logged in: go to account --}}
                                    <a href="/account"
                                        class="list-group-item list-group-item-action py-3 text-primary fw-bold text-center border-dashed">
                                        + Διαχείριση διευθύνσεων
                                    </a>
                                    {{else}}
                                    {{!-- Guest: show inline toggle --}}
                                    <button type="button"
                                        class="list-group-item list-group-item-action py-3 text-primary fw-bold text-center border-dashed btn-toggle-guest-form">
                                        + Αλλαγή διεύθυνσης
                                    </button>
                                    <div id="guestUpdateForm" class="d-none p-3 bg-light border-top">
                                        <form id="browseGuestUpdateForm" action="/browse" method="GET">
                                            <div class="row g-2">
                                                <div class="col-8">
                                                    <input type="text" name="street" id="updateStreet"
                                                        class="form-control form-control-sm" placeholder="Οδός"
                                                        required>
                                                </div>
                                                <div class="col-4">
                                                    <input type="text" name="streetNumber" id="updateNumber"
                                                        class="form-control form-control-sm" placeholder="Αρ." required>
                                                </div>
                                                <div class="col-12">
                                                    <input type="text" name="zipCode" id="updateZip"
                                                        class="form-control form-control-sm" placeholder="Τ.Κ.">
                                                </div>
                                                <input type="hidden" name="latitude" id="updateLatitude">
                                                <input type="hidden" name="longitude" id="updateLongitude">
                                                <div class="col-12 mt-2">
                                                    <button type="button"
                                                        class="btn btn-sm btn-outline-secondary w-100 mb-2 fw-bold"
                                                        id="toggleUpdateMap">
                                                        📍 Χάρτης
                                                    </button>
                                                    <div id="updateMapContainer" class="d-none mt-2">
                                                        <div class="mb-2 position-relative">
                                                            <input type="text" id="updateAddressSearch"
                                                                class="form-control form-control-sm"
                                                                placeholder="Αναζήτηση..." autocomplete="off">
                                                            <div id="updateAddressResults"
                                                                class="list-group mt-1 d-none shadow-sm"
                                                                style="position: absolute; z-index: 1000; width: 100%;">
                                                            </div>
                                                        </div>
                                                        <div id="updateMap" class="map-container-sm"></div>
                                                    </div>
                                                </div>
                                                <div class="col-12 mt-2">
                                                    <button type="submit"
                                                        class="btn btn-menu btn-sm w-100 fw-bold">Ενημέρωση</button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/if}}

        </div>
    </div>
</section>



<section class="container mb-3 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="d-flex gap-2">
                <input type="text" id="searchRestaurant"
                    class="form-control form-control-lg rounded-pill shadow-sm px-4"
                    placeholder="Αναζήτηση για εστιατόριο ή κουζίνα..."
                    value="{{searchQuery}}">
                <button class="btn btn-menu btn-lg px-4 rounded-pill shadow-sm btn-filter-restaurants">Go</button>
            </div>
        </div>
    </div>
</section>

{{!-- Category Buttons --}}
<section class="container mb-5 {{#if noAddress}}d-none{{/if}}" id="categorySection">
    <div class="d-flex align-items-center position-relative">
        <button class="btn btn-light btn-sm rounded-circle shadow-sm me-2" id="scrollLeftBtn" style="width: 36px; height: 36px;">
            <i class="bi bi-chevron-left"></i>
        </button>
        
        <div class="category-scroll d-flex flex-grow-1">
            <div class="category-btn {{#eq activeCategory 'all'}}active{{/eq}} btn-select-category" data-category="all">
                <span class="category-emoji">🍴</span>
                <span class="category-name">Όλα</span>
            </div>
            {{#each categories}}
            <div class="category-btn {{#eq @root.activeCategory name}}active{{/eq}} btn-select-category" data-category="{{name}}">
                {{#if image_url}}
                <img src="{{image_url}}" class="category-img" alt="{{name}}">
                {{else}}
                <span class="category-emoji">{{emoji}}</span>
                {{/if}}
                <span class="category-name">{{name}}</span>
            </div>
            {{/each}}
        </div>

        <button class="btn btn-light btn-sm rounded-circle shadow-sm ms-2" id="scrollRightBtn" style="width: 36px; height: 36px;">
            <i class="bi bi-chevron-right"></i>
        </button>
    </div>
</section>

{{!-- Restaurants: hidden until address is selected --}}
<main class="container mb-5 {{#if noAddress}}d-none{{/if}}" id="restaurantSection">
    <h3 class="h5 mb-4 text-secondary fw-bold">Δημοφιλή Εστιατόρια κοντά σου</h3>

    <div class="row g-4" id="restaurantList">
        {{#each restaurants}}
        <div class="col-12 col-md-6 col-lg-3 restaurant-card-wrapper" data-categories="{{join categories ','}}">
            <div
                class="card h-100 border-0 shadow-sm restaurant-card rounded-4 overflow-hidden {{#eq status 'CLOSED'}}restaurant-closed{{/eq}}">
                <a href="{{#eq status 'CLOSED'}}#{{else}}/restaurant/{{id}}{{/eq}}"
                    class="text-decoration-none h-100 d-flex flex-column {{#eq status 'CLOSED'}}pe-none{{/eq}}">
                    <div class="restaurant-card-photo-wrapper">
                        {{#if image_url}}
                        <img src="{{image_url}}" class="restaurant-card-photo" alt="{{name}}">
                        {{else}}
                        <div class="restaurant-card-photo d-flex align-items-center justify-content-center"
                            style="background-color: #f6f3ff;">
                            <span class="text-muted">LogoFood</span>
                        </div>
                        {{/if}}
                        {{#eq status 'CLOSED'}}
                        <div
                            class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50">
                            <span
                                class="badge bg-danger px-3 py-2 fs-6 shadow-sm border border-2 border-white">ΚΛΕΙΣΤΟ</span>
                        </div>
                        {{/eq}}
                    </div>
                    <div class="card-body p-4 d-flex flex-column h-100 text-dark">
                        <h4 class="card-title h5 fw-bold mb-0 d-flex justify-content-between align-items-center">
                            <span>
                                {{name}}
                                {{#eq status 'CLOSED'}}
                                <small class="text-danger fs-6 ms-1">(ΚΛΕΙΣΤΟ)</small>
                                {{/eq}}
                            </span>
                            <div>
                                {{#if (eq rating_count 0)}}
                                <span class="badge bg-light text-muted border fw-normal smaller"
                                    style="font-size: 0.65rem;">New</span>
                                {{else}}
                                <span class="badge bg-success text-white">{{rating}} <small
                                        style="font-weight: normal; opacity: 0.9;">({{rating_count}})</small></span>
                                {{/if}}
                            </div>
                        </h4>
                        {{#if categories}}
                        <div class="restaurant-card-top-meta mb-2 d-flex flex-wrap align-items-center gap-2">
                            <div class="restaurant-card-category-list">
                                {{#each categories}}
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle me-1 badge-m">{{this}}</span>
                                {{/each}}
                                <span class="restaurant-card-meta-separator">·</span>
                            </div>
                            {{#if deliveryMinutes}}
                            <div class="card-text text-muted restaurant-card-meta">
                                <span>{{deliveryMinutes}}'</span>
                                <span class="restaurant-card-meta-separator">·</span>
                                <span>Ελάχιστη: {{formatPrice min_order_value}}</span>
                            </div>
                            {{/if}}
                        </div>
                        {{else if deliveryMinutes}}
                        <p class="card-text text-muted mb-2 restaurant-card-meta">
                            <span>{{deliveryMinutes}}'</span>
                            <span class="restaurant-card-meta-separator">·</span>
                            <span>Ελάχιστη: {{formatPrice min_order_value}}</span>
                        </p>
                        {{/if}}
                        {{#if outOfReach}}
                        <div class="mb-1">
                            <span class="badge bg-danger text-white">Εκτός εμβέλειας</span>
                        </div>
                        {{/if}}

                        <div class="mt-auto">
                            <span
                                class="btn {{#if outOfReach}}btn-outline-secondary disabled{{else}}{{#eq status 'CLOSED'}}btn-outline-secondary disabled{{else}}btn-menu{{/eq}}{{/if}} w-100 fw-bold py-2 rounded-pill">
                                {{#eq status 'CLOSED'}}Μη Διαθέσιμο{{else}}
                                {{#if outOfReach}}Εκτός εμβέλειας{{else}}Δες το Μενού{{/if}}
                                {{/eq}}
                            </span>
                        </div>
                    </div>
                </a>
            </div>
        </div>
        {{else}}
        <div class="col-12 text-center py-5">
            <p class="text-muted">Δεν βρέθηκαν εστιατόρια στην περιοχή σας. Δοκιμάστε μια άλλη διεύθυνση!</p>
        </div>
        {{/each}}
    </div>

    {{#if (gt pagination.totalPages 1)}}
    <nav aria-label="Page navigation" class="mt-5">
        <ul class="pagination justify-content-center">
            <li class="page-item {{#unless pagination.hasPrev}}disabled{{/unless}}">
                <a class="page-link" href="?page={{pagination.prevPage}}&category={{@root.activeCategory}}&search={{@root.searchQuery}}" aria-label="Previous">
                    <span aria-hidden="true">&laquo; Προηγούμενη</span>
                </a>
            </li>
            {{#each pagination.pages}}
            <li class="page-item {{#eq ../pagination.page this}}active{{/eq}}">
                <a class="page-link" href="?page={{this}}&category={{@root.activeCategory}}&search={{@root.searchQuery}}">{{this}}</a>
            </li>
            {{/each}}
            <li class="page-item {{#unless pagination.hasNext}}disabled{{/unless}}">
                <a class="page-link" href="?page={{pagination.nextPage}}&category={{@root.activeCategory}}&search={{@root.searchQuery}}" aria-label="Next">
                    <span aria-hidden="true">Επόμενη &raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
    {{/if}}
</main>