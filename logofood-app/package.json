{
	"name": "logofood-app",
	"version": "1.0.0",
	"description": "LogoFood – Online Food Delivery (Express + Handlebars SSR)",
	"type": "module",
	"main": "start.mjs",
	"scripts": {
		"start":  "node ./start.mjs",
		"watch":  "node ./node_modules/nodemon/bin/nodemon.js ./start.mjs",
		"debug":  "node ./node_modules/nodemon/bin/nodemon.js --inspect ./start.mjs",
		"clean":  "rm -rf node_modules",
		"reinstall": "npm run clean && npm install"
	},
	"nodemonConfig": {
		"ignore": ["public/**"]
	},
	"engines": {
		"node": "^22.x"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"bcrypt":              "^5.1.1",
		"connect-flash":      "^0.1.1",
		"dotenv":             "^16.5.0",
		"express":            "^5.1.0",
		"express-handlebars": "^8.0.3",
		"express-session":    "^1.18.1",
		"mysql2":             "^3.11.5"
	},
	"devDependencies": {
		"nodemon": "^3.1.10"
	}
}
