{{!-- views/account.hbs — Customer profile & addresses --}}
<main class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <h2 class="fw-bold mb-4 text-center">Διαχείριση Λογαριασμού</h2>
            
            {{!-- Quick Links / Orders --}}
            <div class="card border-0 shadow-sm p-4 mb-4 text-center rounded-4" style="background: var(--surface-soft);">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="text-start">
                        <h4 class="fw-bold mb-1">Οι Παραγγελίες μου</h4>
                        <p class="text-muted small mb-0">Δείτε την εξέλιξη των ενεργών παραγγελιών σας και το ιστορικό σας.</p>
                    </div>
                    <a href="/track-orders" class="btn btn-menu fw-bold px-4">Προβολή</a>
                </div>
            </div>

            {{!-- Profile Card --}}
            <div class="card border-0 shadow-sm p-4 mb-4 rounded-4">
                <h4 class="fw-bold mb-3">Προφίλ</h4>
                <form method="POST" action="/account/profile">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="firstName" class="form-label text-muted small fw-bold">Όνομα</label>
                            <input type="text" id="firstName" name="firstName" class="form-control" 
                                   value="{{user.firstName}}" required>
                        </div>
                        <div class="col-md-4">
                            <label for="lastName" class="form-label text-muted small fw-bold">Επώνυμο</label>
                            <input type="text" id="lastName" name="lastName" class="form-control" 
                                   value="{{user.lastName}}" required>
                        </div>
                        <div class="col-md-4">
                            <label for="contactPhone" class="form-label text-muted small fw-bold">Τηλέφωνο</label>
                            <input type="tel" id="contactPhone" name="contactPhone" class="form-control" 
                                   value="{{user.contactPhone}}" required>
                        </div>
                        <div class="col-12 mt-3 text-end">
                            <button type="submit" class="btn btn-menu fw-bold px-4">Αποθήκευση</button>
                        </div>
                    </div>
                </form>
            </div>

            {{!-- Addresses Card --}}
            <div class="card border-0 shadow-sm p-4 mb-4 rounded-4">
                <h4 class="fw-bold mb-3">Διευθύνσεις Παράδοσης</h4>

                <div class="accordion mb-4" id="addressAccordion">
                    <div class="accordion-item border-0 bg-light rounded-4 overflow-hidden">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed fw-bold bg-light" type="button" 
                                    data-bs-toggle="collapse" data-bs-target="#collapseAddresses">
                                Οι διευθύνσεις μου ({{addresses.length}})
                            </button>
                        </h2>
                        <div id="collapseAddresses" class="accordion-collapse collapse" data-bs-parent="#addressAccordion">
                            <div class="accordion-body p-0">
                                <div class="list-group list-group-flush">
                                    {{#each addresses}}
                                    <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent py-3">
                                        <div>
                                            <div class="fw-bold">{{street}} {{street_number}}{{#if floor}}, 'Οροφος: {{floor}}{{/if}}</div>
                                            <div class="text-muted small">{{zip_code}}{{#if comments}} | {{comments}}{{/if}}</div>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-link text-primary p-0 edit-address-btn" 
                                                    data-id="{{id}}" 
                                                    data-street="{{street}}" 
                                                    data-number="{{street_number}}" 
                                                    data-zip="{{zip_code}}" 
                                                    data-floor="{{floor}}" 
                                                    data-comments="{{comments}}"
                                                    data-lat="{{latitude}}"
                                                    data-lon="{{longitude}}">✏️</button>
                                            <form method="POST" action="/account/addresses/{{id}}/delete">
                                                <button type="submit" class="btn btn-link text-danger p-0 btn-confirm" data-confirm="Διαγραφή διεύθυνσης;">🗑</button>
                                            </form>
                                        </div>
                                    </div>
                                    {{/each}}
                                    {{#unless addresses}}
                                    <div class="p-4 text-center text-muted small">Δεν υπάρχουν αποθηκευμένες διευθύνσεις.</div>
                                    {{/unless}}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold mb-3 h6">Προσθήκη Νέας Διεύθυνσης</h5>
                <form id="addAddressForm" method="POST" action="/account/addresses">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label for="street" class="form-label text-muted small fw-bold">Οδός</label>
                            <input type="text" id="accountStreet" name="street" class="form-control" placeholder="π.χ. Ερμού" required>
                        </div>
                        <div class="col-md-3">
                            <label for="streetNumber" class="form-label text-muted small fw-bold">Αριθμός</label>
                            <input type="text" id="accountNumber" name="streetNumber" class="form-control" placeholder="π.χ. 12" required>
                        </div>
                        <div class="col-md-4">
                            <label for="zipCode" class="form-label text-muted small fw-bold">Τ.Κ.</label>
                            <input type="text" id="accountZip" name="zipCode" class="form-control" placeholder="10563">
                        </div>
                        <input type="hidden" id="accountLatitude" name="latitude">
                        <input type="hidden" id="accountLongitude" name="longitude">
                        <div class="col-12">
                            <button type="button" class="btn btn-sm btn-outline-secondary w-100 mb-2 fw-bold" id="toggleAccountMap">
                                📍 Επιλογή στο χάρτη
                            </button>
                            <div id="accountMapContainer" class="d-none mt-3">
                                <div class="mb-3 position-relative">
                                    <label for="accountAddressSearch" class="form-label">Αναζήτηση διεύθυνσης</label>
                                    <input type="text" id="accountAddressSearch" class="form-control" placeholder="π.χ. Ερμού 12" autocomplete="off">
                                    <div id="accountAddressResults" class="list-group mt-2 d-none"></div>
                                </div>
                                <div id="accountMap" class="map-container-lg"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold">Όροφος/Διαμέρισμα (Απαραίτητο)</label>
                            <input type="text" name="floor" class="form-control" placeholder="π.χ. 3ος / Παπαδόπουλος" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold">Σχόλια Διανομέα (Προαιρετικό)</label>
                            <textarea name="comments" class="form-control" rows="1" placeholder="π.χ. Το κουδούνι δεν λειτουργεί..."></textarea>
                        </div>
                        <div class="col-12 text-end">
                            <button type="submit" class="btn btn-menu fw-bold px-4">Προσθήκη</button>
                        </div>
                    </div>
                </form>
            </div>

            {{!-- Security Card --}}
            <div class="card border-0 shadow-sm p-4 mb-4 rounded-4">
                <h4 class="fw-bold mb-3">Ασφάλεια</h4>
                <div class="text-muted small mb-0">Η αλλαγή κωδικού είναι προσωρινά μη διαθέσιμη.</div>
            </div>

        </div>
    </div>
</main>

<!-- Edit Address Modal -->
<div class="modal fade" id="editAddressModal" tabindex="-1" aria-labelledby="editAddressModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="editAddressModalLabel">Επεξεργασία Διεύθυνσης</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editAddressForm" method="POST">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label text-muted small fw-bold">Οδός</label>
                            <input type="text" id="editStreet" name="street" class="form-control" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold">Αριθμός</label>
                            <input type="text" id="editNumber" name="streetNumber" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold">Τ.Κ.</label>
                            <input type="text" id="editZip" name="zipCode" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold">Όροφος</label>
                            <input type="text" id="editFloor" name="floor" class="form-control" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold">Σχόλια Διανομέα</label>
                            <textarea id="editComments" name="comments" class="form-control" rows="2"></textarea>
                        </div>
                        <input type="hidden" id="editLatitude" name="latitude">
                        <input type="hidden" id="editLongitude" name="longitude">
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Άκυρο</button>
                    <button type="submit" class="btn btn-menu fw-bold px-4">Ενημέρωση</button>
                </div>
            </form>
        </div>
    </div>
</div>

