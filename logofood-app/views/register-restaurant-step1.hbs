{{!-- views/register-restaurant-step1.hbs --}}
<main class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <h2 class="fw-bold mb-2 text-center">Εγγραφή Εστιατορίου</h2>
                <p class="text-muted text-center mb-4">Βήμα 1: Στοιχεία Υπευθύνου</p>

                <form action="/register-restaurant/step1" method="POST">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="firstNameOwner" class="form-label text-muted small fw-bold">Όνομα Ιδιοκτήτη</label>
                            <input type="text" id="firstNameOwner" name="firstNameOwner" class="form-control" 
                                   placeholder="Γιώργος" value="{{userInput.firstNameOwner}}" required>
                            {{#if errors.firstNameOwner}}<div class="text-danger small mt-1">{{errors.firstNameOwner}}</div>{{/if}}
                        </div>

                        <div class="col-md-6">
                            <label for="lastNameOwner" class="form-label text-muted small fw-bold">Επώνυμο Ιδιοκτήτη</label>
                            <input type="text" id="lastNameOwner" name="lastNameOwner" class="form-control" 
                                   placeholder="Παπαδόπουλος" value="{{userInput.lastNameOwner}}" required>
                            {{#if errors.lastNameOwner}}<div class="text-danger small mt-1">{{errors.lastNameOwner}}</div>{{/if}}
                        </div>

                        <div class="col-12">
                            <label for="email" class="form-label text-muted small fw-bold">Email (θα χρησιμοποιηθεί για login)</label>
                            <input type="email" id="email" name="email" class="form-control" 
                                   placeholder="example@example.com" value="{{userInput.email}}" required>
                            {{#if errors.email}}<div class="text-danger small mt-1">{{errors.email}}</div>{{/if}}
                        </div>

                        <div class="col-12">
                            <label for="password" class="form-label text-muted small fw-bold">Κωδικός Πρόσβασης</label>
                            <div class="input-group">
                                <input type="password" id="password" name="password" class="form-control rounded-start-custom" 
                                       placeholder="Τουλάχιστον 6 χαρακτήρες" required minlength="6">
                                <button class="btn btn-outline-secondary border-secondary-subtle rounded-end-custom" type="button" id="togglePassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            {{#if errors.password}}<div class="text-danger small mt-1">{{errors.password}}</div>{{/if}}
                        </div>

                        <div class="col-12">
                            <label for="confirmPassword" class="form-label text-muted small fw-bold">Επιβεβαίωση Κωδικού</label>
                            <div class="input-group">
                                <input type="password" id="confirmPassword" name="confirmPassword" class="form-control rounded-start-custom"
                                       placeholder="Επαναλάβετε τον κωδικό" required minlength="6">
                                <button class="btn btn-outline-secondary border-secondary-subtle rounded-end-custom" type="button" id="toggleConfirmPassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            {{#if errors.confirmPassword}}<div class="text-danger small mt-1">{{errors.confirmPassword}}</div>{{/if}}
                        </div>

                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-menu btn-lg w-100 fw-bold shadow-sm">Επόμενο Βήμα <i class="bi bi-arrow-right ms-2"></i></button>
                        </div>

                        <div class="col-12 text-center mt-3">
                            <span class="text-muted small">Έχετε ήδη λογαριασμό? </span>
                            <a href="/login" class="text-decoration-none text-primary small fw-bold">Συνδεθείτε εδώ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
