{{!-- views/cart.hbs — Cart & Checkout --}}
<main class="container my-5">
    <h2 class="fw-bold mb-4">Το Καλάθι σου (´｡• ᵕ •｡`) ♡</h2>

    {{#if cart.length}}
    <div class="row g-4">
        <div class="col-lg-8">

            {{!-- Step 1: Delivery --}}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">
                        <span class="badge custom-number me-2">1</span>Στοιχεία Παράδοσης
                    </h5>

                    {{#if user}}
                    <form id="checkoutForm" method="POST" action="/cart/checkout">
                        {{#if addresses.length}}
                        <div class="accordion mb-4" id="cartAddressAccordion">
                            <div class="accordion-item border-0 bg-light rounded-4 overflow-hidden">
                                <h2 class="accordion-header">
                                    <button class="accordion-button fw-bold bg-light" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#collapseCartAddresses">
                                        <i class="bi bi-geo-alt-fill me-2 text-primary"></i>
                                        Επιλέξτε Διεύθυνση Παράδοσης ({{addresses.length}})
                                    </button>
                                </h2>
                                <div id="collapseCartAddresses" class="accordion-collapse collapse show"
                                    data-bs-parent="#cartAddressAccordion">
                                    <div class="accordion-body p-0">
                                        <div class="list-group list-group-flush">
                                            {{#each addresses}}
                                            <label
                                                class="list-group-item d-flex gap-3 py-3 border-0 bg-transparent mb-0">
                                                <input class="form-check-input flex-shrink-0 address-radio" type="radio"
                                                    name="addressId" value="{{id}}" data-floor="{{floor}}"
                                                    data-comments="{{comments}}" {{#if @first}}checked{{/if}}>
                                                <span class="pt-1 small">
                                                    <strong>{{street}} {{street_number}}</strong>
                                                    {{#if zip_code}}<br><span
                                                        class="text-muted">{{zip_code}}</span>{{/if}}
                                                </span>
                                            </label>
                                            {{/each}}
                                            <a href="/account"
                                                class="list-group-item list-group-item-action py-3 text-primary fw-bold text-center border-dashed border-0">
                                                + Προσθήκη/Διαχείριση διευθύνσεων
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-4 mt-2">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label text-muted small fw-bold">Όροφος/Διαμέρισμα (Απαραίτητο)</label>
                                    <input type="text" name="floor" id="selectedFloor" class="form-control"
                                        placeholder="π.χ. 3ος / Παπαδόπουλος" required>
                                </div>
                                <div>
                                    <label class="form-label text-muted small fw-bold">Τηλέφωνο (Απαραίτητο)</label>
                                    <input type="tel" name="phone" id="selectedPhone" class="form-control"
                                        placeholder="π.χ. 6912345678" value="{{customer.contact_phone}}" data-default-phone="{{customer.contact_phone}}" required>
                                </div>
                            </div>
                            <div class="col-md-6 d-flex flex-column">
                                <label class="form-label text-muted small fw-bold">Σχόλια Διανομέα (Προαιρετικό)</label>
                                <textarea name="comments" id="selectedComments" class="form-control flex-grow-1 min-h-110"
                                    placeholder="π.χ. Το κουδούνι δεν λειτουργεί..."></textarea>
                            </div>
                        </div>
                        {{else}}
                        <div class="alert alert-warning border-0 rounded-4">
                            Δεν έχεις αποθηκευμένη διεύθυνση. <a href="/account" class="fw-bold">Πρόσθεσε μία εδώ.</a>
                        </div>
                        {{/if}}
                    </form>
                    {{else}}
                    {{!-- Guest Address Section (Matching cart.html) --}}
                    <form id="checkoutForm" method="POST" action="/cart/checkout">
                        <div id="guestAddressSection">
                            <div class="alert alert-info border-0 rounded-4 mb-4">
                                <p class="mb-1 fw-bold small">Είσαι επισκέπτης</p>
                                <p class="mb-0 small text-muted">Συνδεθείτε για να χρησιμοποιήσετε τις αποθηκευμένες σας
                                    διευθύνσεις και την δυνατότητα Live Tracking ή συμπληρώστε τα παρακάτω.</p>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <label class="form-label text-muted small fw-bold">Οδός</label>
                                    <input type="text" name="street" id="guestStreet" class="form-control"
                                        placeholder="π.χ. Ερμού" value="{{deliveryAddress.street}}">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small fw-bold">Αριθμός</label>
                                    <input type="text" name="streetNumber" id="guestNumber" class="form-control"
                                        placeholder="Αρ." value="{{deliveryAddress.streetNumber}}">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label text-muted small fw-bold">Τ.Κ.</label>
                                    <input type="text" name="zipCode" id="guestZip" class="form-control"
                                        placeholder="Τ.Κ." value="{{deliveryAddress.zipCode}}">
                                </div>
                                <input type="hidden" name="latitude" id="cartLatitude" value="{{deliveryAddress.latitude}}">
                                <input type="hidden" name="longitude" id="cartLongitude" value="{{deliveryAddress.longitude}}">
                                <div class="col-12">
                                    <button type="button" class="btn btn-sm btn-outline-secondary w-100 mb-2 fw-bold"
                                        id="toggleCartMap">
                                        📍 Επιλογή στο χάρτη
                                    </button>
                                    <div id="cartMapContainer" class="d-none mt-3">
                                        <div class="mb-3 position-relative">
                                            <label for="cartAddressSearch" class="form-label">Αναζήτηση
                                                διεύθυνσης</label>
                                            <input type="text" id="cartAddressSearch" class="form-control"
                                                placeholder="π.χ. Ερμού 12" autocomplete="off">
                                            <div id="cartAddressResults" class="list-group mt-2 d-none"></div>
                                        </div>
                                        <div id="cartMap" class="map-container-lg"></div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label text-muted small fw-bold">Όροφος/Διαμέρισμα (Απαραίτητο)</label>
                                        <input type="text" name="floor" class="form-control"
                                            placeholder="π.χ. 3ος / Παπαδόπουλος" required>
                                    </div>
                                    <div>
                                        <label class="form-label text-muted small fw-bold">Τηλέφωνο (Απαραίτητο)</label>
                                        <input type="tel" name="phone" class="form-control"
                                            placeholder="π.χ. 6912345678" required>
                                    </div>
                                </div>
                                <div class="col-md-6 d-flex flex-column">
                                    <label class="form-label text-muted small fw-bold">Σχόλια για τον διανομέα</label>
                                    <textarea name="comments" class="form-control flex-grow-1 min-h-110"
                                        placeholder="π.χ. Το κουδούνι δεν λειτουργεί..."></textarea>
                                </div>
                            </div>
                        </div>
                    </form>
                    {{/if}}
                </div>
            </div>

            {{!-- Step 2: Order Items --}}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">
                        <span class="badge custom-number me-2">2</span>Η Παραγγελία σου
                    </h5>
                    <div id="cartItemsContainer">
                        {{#each cart}}
                        <div
                            class="d-flex align-items-center justify-content-between py-3 {{#unless @last}}border-bottom{{/unless}}">
                            <div>
                                <h6 class="fw-bold mb-0">{{name}}</h6>
                                <span class="text-muted small">{{formatPrice price}}</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="d-flex align-items-center bg-white border border-2 border-secondary rounded-pill px-2 py-2 shadow-sm line-height-1">
                                    <button
                                        class="btn btn-danger btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center btn-circle-xs btn-cart-qty"
                                        data-product-id="{{productId}}" data-delta="-1">−</button>
                                    <span class="px-2 small fw-bold">{{quantity}}</span>
                                    <button
                                        class="btn btn-success btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center btn-circle-xs btn-cart-qty"
                                        data-product-id="{{productId}}" data-delta="1">+</button>
                                </div>
                                <span class="fw-bold">{{formatPrice (totalPrice price quantity)}}</span>
                                <button class="btn btn-outline-danger btn-sm rounded-circle btn-cart-delete"
                                    data-product-id="{{productId}}">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
            </div>

            {{!-- Step 3: Payment --}}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">
                        <span class="badge custom-number me-2">3</span>Τρόπος Πληρωμής
                    </h5>
                    <div class="form-check border p-3 rounded mb-3">
                        <input class="form-check-input mt-1 ms-0 me-3" type="radio" name="paymentOption" id="card"
                            checked>
                        <label class="form-check-label fw-bold d-block" for="card">
                            Πιστωτική / Χρεωστική Κάρτα
                            <div class="text-muted small fw-normal">Θα μεταφερθείτε σε ασφαλές περιβάλλον τράπεζας.
                            </div>
                        </label>
                    </div>
                    <div class="form-check border p-3 rounded">
                        <input class="form-check-input mt-1 ms-0 me-3" type="radio" name="paymentOption" id="cash">
                        <label class="form-check-label fw-bold" for="cash">Μετρητά κατά την παράδοση</label>
                    </div>
                </div>
            </div>
        </div>

        {{!-- Summary Sidebar --}}
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm sticky-top" style="top: 6rem;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-center">Σύνοψη Παραγγελίας</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Αξία προϊόντων</span>
                        <span>{{formatPrice total}}</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Κόστος Διανομής</span>
                        <span>1,00 €</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
                        <span class="h5 fw-bold mb-0">Σύνολο Τιμής</span>
                        <span class="h4 fw-bold mb-0 text-danger">{{formatPrice (add total 1)}}</span>
                    </div>
                    <button id="btnSubmitCart"
                        class="btn btn-menu btn-lg w-100 fw-bold py-3 shadow-sm">Παραγγελία Τώρα!</button>
                </div>
            </div>
        </div>
    </div>
    {{else}}
    <div class="text-center py-5">
        <div class="display-1 mb-4">🛒</div>
        <h3 class="fw-bold">Το καλάθι σου είναι άδειο</h3>
        <p class="text-muted mb-4">Πρόσθεσε μερικές λιχουδιές για να συνεχίσεις!</p>
        <a href="/browse" class="btn btn-custom px-5 py-3 fw-bold">Βρες Εστιατόριο</a>
    </div>
    {{/if}}
</main>