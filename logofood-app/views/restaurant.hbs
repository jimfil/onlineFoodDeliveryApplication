{{!-- views/restaurant.hbs — Single restaurant menu --}}
{{!-- Restaurant Info Hero --}}
<section class="container mt-4 mb-5">
    <div class="card border-0 shadow-sm overflow-hidden rounded-4">
        <div class="restaurant-banner-wrapper" style="height: 200px; overflow: hidden; position: relative;">
            {{#if restaurant.image_url}}
            <img src="{{restaurant.image_url}}" class="restaurant-banner" alt="{{restaurant.name}}">
            {{else}}
            <div class="restaurant-banner d-flex align-items-center justify-content-center bg-light">
                <span class="text-muted">LogoFood</span>
            </div>
            {{/if}}
        </div>
        <div class="card-body text-center py-4 position-relative">
            {{#eq restaurant.status 'CLOSED'}}
            <div class="alert alert-danger mb-4 py-3 border-0 rounded-4 shadow-sm">
                <i class="bi bi-door-closed-fill me-2 fs-5"></i>
                <span class="fw-bold">ΤΟ ΚΑΤΑΣΤΗΜΑ ΕΙΝΑΙ ΠΡΟΣΩΡΙΝΑ ΚΛΕΙΣΤΟ</span>
                <div class="smaller">Δεν είναι δυνατή η προσθήκη προϊόντων στο καλάθι.</div>
            </div>
            {{/eq}}

            <h2 class="fw-bold mb-2">{{restaurant.name}}</h2>
            {{#if restaurant.categories}}
            <div class="mb-3">
                {{#each restaurant.categories}}
                <span class="badge bg-primary me-2 fs-6 px-3 py-2">{{this}}</span>
                {{/each}}
            </div>
            {{/if}}
            <p class="text-muted mb-3">{{restaurant.description}}</p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <span class="badge bg-success bg-opacity-10 text-success p-2 px-3 rounded-pill fs-6">
                    {{#if (eq restaurant.rating_count 0)}}
                    No ratings yet
                    {{else}}
                    ⭐ {{roundStars restaurant.rating}}/5 ({{restaurant.rating_count}})
                    {{/if}}
                </span>
                <span class="badge bg-primary bg-opacity-10 text-primary p-2 px-3 rounded-pill fs-6">🕒
                    {{restaurant.estimated_preparation_time}}'</span>
                {{#if restaurant.min_order_value}}
                <span class="badge bg-primary bg-opacity-10 text-primary p-2 px-3 rounded-pill fs-6">🛵 Ελάχιστη
                    {{formatPrice restaurant.min_order_value}}</span>
                {{/if}}
            </div>
        </div>
    </div>
</section>

<main class="container mb-5">
    <h3 class="h4 fw-bold mb-4">Επιλογές Μενού</h3>

    <div class="row g-4">
        {{#each categories}}
        {{#if products.length}}
        <div class="col-12 mt-5 mb-2">
            <h4 class="h5 fw-bold text-primary border-start border-4 border-primary ps-3">{{categoryName}}</h4>
        </div>
        {{#each products}}
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden product-card">
                <div class="row g-0 h-100 align-items-center">
                    <div class="col-4 bg-light text-muted d-flex justify-content-center align-items-center h-100 min-h-140"
                        style="background: url('{{image_url}}') center/cover no-repeat;">
                        {{#unless image_url}}
                        <small>Φωτό</small>
                        {{/unless}}
                    </div>
                    <div class="col-8">
                        <div class="card-body d-flex flex-column h-100">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h5 class="card-title fw-bold mb-0 small">{{name}}</h5>
                                <span class="fw-bold text-danger small">{{formatPrice price}}</span>
                            </div>
                            <p class="card-text text-muted smaller mb-3">{{description}}</p>
                            <div class="mt-auto text-end d-flex align-items-center justify-content-end min-h-40" id="actions-{{id}}">
                                {{#if (eq ../../restaurant.status 'CLOSED')}}
                                    <button class="btn btn-outline-secondary btn-sm px-3 fw-bold rounded-pill disabled">
                                        Μη Διαθέσιμο
                                    </button>
                                {{else}}
                                    {{#if (getItemQty ../../cart id)}}
                                        <div class="d-flex align-items-center justify-content-end gap-2 bg-white border border-2 border-secondary rounded-pill px-2 py-2 d-inline-flex shadow-sm line-height-1">
                                        <button
                                            class="btn btn-danger btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center btn-circle-xs btn-restaurant-qty"
                                            data-product-id="{{id}}" data-delta="-1" data-name="{{name}}" data-price="{{price}}" data-restaurant-id="{{../../restaurant.id}}">−</button>
                                        <span class="px-2 small fw-bold" id="qty-{{id}}">{{getItemQty ../../cart id}}</span>
                                        <button
                                            class="btn btn-success btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center btn-circle-xs btn-restaurant-qty"
                                            data-product-id="{{id}}" data-delta="1" data-name="{{name}}" data-price="{{price}}" data-restaurant-id="{{../../restaurant.id}}">+</button>
                                    </div>
                                    {{else}}
                                    <button class="btn btn-menu btn-sm px-3 fw-bold rounded-pill btn-restaurant-qty"
                                        data-product-id="{{id}}" data-delta="1" data-name="{{name}}" data-price="{{price}}" data-restaurant-id="{{../../restaurant.id}}">
                                        + Προσθήκη
                                    </button>
                                    {{/if}}
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{/each}}
        {{/if}}
        {{/each}}
    </div>
</main>