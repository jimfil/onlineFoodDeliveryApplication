{{!-- views/login.hbs --}}
<main class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <h2 class="fw-bold mb-4 text-center">Σύνδεση</h2>

                <form action="/login" method="POST">
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="email" class="form-label text-muted small fw-bold">Email</label>
                            <input type="email" id="email" name="email" class="form-control" 
                                   placeholder="example@example.com" required>
                        </div>

                        <div class="col-12">
                            <label for="password" class="form-label text-muted small fw-bold">Κωδικός Πρόσβασης</label>
                            <input type="password" id="password" name="password" class="form-control" 
                                   placeholder="Τουλάχιστον 6 χαρακτήρες" required>
                        </div>

                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-menu btn-lg w-100 fw-bold shadow-sm">Σύνδεση</button>
                        </div>

                        <div class="col-12 text-center mt-3">
                            <a href="/register" class="text-decoration-none text-muted small">
                                Δεν έχετε λογαριασμό? Δημιουργήστε έναν εδώ
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
