{
	"name": "logofood-app",
	"version": "1.0.0",
	"description": "LogoFood – Online Food Delivery",
	"type": "module",
	"main": "start.mjs",
	"scripts": {
		"start": "node ./start.mjs",
		"watch": "node ./node_modules/nodemon/bin/nodemon.js ./start.mjs",
		"debug": "node ./node_modules/nodemon/bin/nodemon.js --inspect ./start.mjs",
		"clean": "rm -rf node_modules",
		"reinstall": "npm run clean && npm install",
		"db:init": "node ./scripts/init-db.mjs"
	},
	"nodemonConfig": {
		"ignore": [
			"public/**"
		]
	},
	"engines": {
		"node": ">=22.x"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"bcrypt": "^5.1.1",
		"connect-flash": "^0.1.1",
		"dotenv": "^16.6.1",
		"express": "^5.2.1",
		"express-handlebars": "^8.0.7",
		"express-session": "^1.19.0",
		"express-validator": "^7.3.2",
		"mysql2": "^3.22.3"
	},
	"devDependencies": {
		"nodemon": "^3.1.14"
	}
}
