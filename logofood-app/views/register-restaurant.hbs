{{!-- views/register-restaurant.hbs --}}
<main class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <h2 class="fw-bold mb-4 text-center">Δημιουργία Λογαριασμού Εστιατορίου</h2>

                <form action="/register-restaurant" method="POST">
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="businessName" class="form-label text-muted small fw-bold">Όνομα Επιχείρησης</label>
                            <input type="text" id="businessName" name="businessName" class="form-control" 
                                   placeholder="π.χ. Burger House" required>
                        </div>

                        <div class="col-md-6">
                            <label for="firstNameOwner" class="form-label text-muted small fw-bold">Όνομα Ιδιοκτήτη</label>
                            <input type="text" id="firstNameOwner" name="firstNameOwner" class="form-control" 
                                   placeholder="Γιώργος" required>
                        </div>

                        <div class="col-md-6">
                            <label for="lastNameOwner" class="form-label text-muted small fw-bold">Επώνυμο Ιδιοκτήτη</label>
                            <input type="text" id="lastNameOwner" name="lastNameOwner" class="form-control" 
                                   placeholder="Παπαδόπουλος" required>
                        </div>

                        <div class="col-md-12">
                            <label for="afm" class="form-label text-muted small fw-bold">Α.Φ.Μ.</label>
                            <input type="text" id="afm" name="afm" class="form-control" 
                                   placeholder="123456789" required>
                        </div>

                        <div class="col-12">
                            <label for="email" class="form-label text-muted small fw-bold">Email</label>
                            <input type="email" id="email" name="email" class="form-control" 
                                   placeholder="example@example.com" required>
                        </div>

                        <div class="col-12">
                            <label for="password" class="form-label text-muted small fw-bold">Κωδικός Πρόσβασης</label>
                            <div class="input-group">
                                <input type="password" id="password" name="password" class="form-control" 
                                       placeholder="Τουλάχιστον 6 χαρακτήρες" required minlength="6"
                                       style="border-top-left-radius: 1.25rem; border-bottom-left-radius: 1.25rem;">
                                <button class="btn btn-outline-secondary border-secondary-subtle" type="button" id="togglePassword"
                                        style="border-top-right-radius: 1.25rem; border-bottom-right-radius: 1.25rem;">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <script>
                            document.getElementById('togglePassword').addEventListener('click', function() {
                                const passwordInput = document.getElementById('password');
                                const icon = this.querySelector('i');
                                if (passwordInput.type === 'password') {
                                    passwordInput.type = 'text';
                                    icon.classList.replace('bi-eye', 'bi-eye-slash');
                                } else {
                                    passwordInput.type = 'password';
                                    icon.classList.replace('bi-eye-slash', 'bi-eye');
                                }
                            });
                        </script>

                        <div class="col-12">
                            <label for="phone" class="form-label text-muted small fw-bold">Τηλέφωνο</label>
                            <input type="tel" id="phone" name="phone" class="form-control" 
                                   placeholder="69xxxxxxxx" required>
                        </div>

                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-menu btn-lg w-100 fw-bold shadow-sm">Δημιουργία Λογαριασμού</button>
                        </div>

                        <div class="col-12 text-center mt-3">
                            <span class="text-muted small">Έχετε ήδη λογαριασμό? </span>
                            <a href="/login" class="text-decoration-none text-primary small fw-bold">Συνδεθείτε εδώ</a>
                        </div>

                        <div class="col-12 text-center mt-2">
                            <hr class="text-muted opacity-25">
                            <p class="text-muted small mb-1">Θέλετε να παραγγείλετε;</p>
                            <a href="/register" class="text-decoration-none text-primary small fw-bold">Κάντε λογαριασμό εδώ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
