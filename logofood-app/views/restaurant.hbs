{{!-- views/restaurant.hbs — Single restaurant menu --}}
{{!-- Restaurant Info Hero --}}
<section class="container mt-4 mb-5">
    <div class="card border-0 shadow-sm overflow-hidden rounded-4">
        <div class="bg-light d-flex justify-content-center align-items-center"
            style="height: 200px; background: url('{{restaurant.image_url}}') center/cover no-repeat;">
            {{#unless restaurant.image_url}}
            <span class="text-muted">LogoFood</span>
            {{/unless}}
        </div>
        <div class="card-body text-center py-4">
            <h2 class="fw-bold mb-2">{{restaurant.name}}</h2>
            <p class="text-muted mb-3">{{restaurant.description}}</p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <span class="badge bg-success bg-opacity-10 text-success p-2 px-3 rounded-pill">⭐ {{restaurant.rating}}/5</span>
                <span class="badge bg-primary bg-opacity-10 text-primary p-2 px-3 rounded-pill">🕒
                    {{restaurant.estimated_preparation_time}}'</span>
                <span class="badge bg-primary bg-opacity-10 text-primary p-2 px-3 rounded-pill">🛵 Ελάχιστη
                    {{formatPrice 8}}</span>
            </div>
        </div>
    </div>
</section>

<main class="container mb-5">
    <h3 class="h4 fw-bold mb-4">Επιλογές Μενού</h3>

    <div class="row g-4">
        {{#each categories}}
        {{#if products.length}}
        <div class="col-12 mt-5 mb-2">
            <h4 class="h5 fw-bold text-primary border-start border-4 border-primary ps-3">{{categoryName}}</h4>
        </div>
        {{#each products}}
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden product-card">
                <div class="row g-0 h-100 align-items-center">
                    <div class="col-4 bg-light text-muted d-flex justify-content-center align-items-center h-100"
                        style="min-height: 140px; background: url('{{image_url}}') center/cover no-repeat;">
                        {{#unless image_url}}
                        <small>Φωτό</small>
                        {{/unless}}
                    </div>
                    <div class="col-8">
                        <div class="card-body d-flex flex-column h-100">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h5 class="card-title fw-bold mb-0 small">{{name}}</h5>
                                <span class="fw-bold text-danger small">{{formatPrice price}}</span>
                            </div>
                            <p class="card-text text-muted smaller mb-3">{{description}}</p>
                            <div class="mt-auto text-end d-flex align-items-center justify-content-end" id="actions-{{id}}" style="min-height: 40px;">
                                {{#if (getItemQty ../../cart id)}}
                                    <div class="d-flex align-items-center justify-content-end gap-2 bg-white border border-2 border-secondary rounded-pill px-2 py-2 d-inline-flex shadow-sm" style="line-height: 1;">
                                    <button
                                        class="btn btn-danger btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center"
                                        style="width: 24px; height: 24px;"
                                        onclick="changeQty({{id}}, -1, '{{name}}', {{price}}, {{../../restaurant.id}})">−</button>
                                    <span class="px-2 small fw-bold" id="qty-{{id}}">{{getItemQty ../../cart id}}</span>
                                    <button
                                        class="btn btn-success btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center"
                                        style="width: 24px; height: 24px;"
                                        onclick="changeQty({{id}}, 1, '{{name}}', {{price}}, {{../../restaurant.id}})">+</button>
                                </div>
                                {{else}}
                                <button class="btn btn-menu btn-sm px-3 fw-bold rounded-pill"
                                    onclick="changeQty({{id}}, 1, '{{name}}', {{price}}, {{../../restaurant.id}})">
                                    + Προσθήκη
                                </button>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{/each}}
        {{/if}}
        {{/each}}
    </div>
</main>

<script>
    async function changeQty(productId, delta, name, price, restaurantId) {
        const endpoint = delta > 0 ? '/cart/add' : '/cart/remove';
        const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId, name, price, restaurantId })
        });

        if (res.ok) {
            const data = await res.json();
            document.getElementById('cartBadge').textContent = data.cartCount;

            // Find the quantity for this specific product in the new cart state
            const item = data.cart.find(i => i.productId == productId);
            const newQty = item ? item.quantity : 0;

            const container = document.getElementById(`actions-${productId}`);
            if (newQty > 0) {
                container.innerHTML = `
                <div class="d-flex align-items-center justify-content-end gap-2 bg-white border border-2 border-secondary rounded-pill px-2 py-2 d-inline-flex shadow-sm" style="line-height: 1;">
                    <button class="btn btn-danger btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center" style="width: 24px; height: 24px;" onclick="changeQty(${productId}, -1, '${name}', ${price}, ${restaurantId})">−</button>
                    <span class="px-2 small fw-bold" id="qty-${productId}">${newQty}</span>
                    <button class="btn btn-success btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center" style="width: 24px; height: 24px;" onclick="changeQty(${productId}, 1, '${name}', ${price}, ${restaurantId})">+</button>
                </div>
            `;
            } else {
                container.innerHTML = `
                <button class="btn btn-menu btn-sm px-3 fw-bold rounded-pill" 
                        onclick="changeQty(${productId}, 1, '${name}', ${price}, ${restaurantId})">
                    + Προσθήκη
                </button>
            `;
            }
        } else {
            const data = await res.json();
            alert(data.error || 'Σφάλμα κατά την ενημέρωση του καλαθιού');
        }
    }
</script>