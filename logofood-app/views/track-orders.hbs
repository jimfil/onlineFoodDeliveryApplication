{{!-- views/track-orders.hbs — Customer order tracking --}}
<main class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <h2 class="fw-bold mb-4 text-center">Οι Παραγγελίες μου</h2>

            {{#if orders.length}}
            {{#each orders}}
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                <div class="card-header bg-white border-0 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="fw-bold mb-0 text-primary">{{restaurantName}}</h4>
                            <div class="small text-muted mb-1">
                                #{{id}} • {{formatTime created_at}}
                                {{#eq status 'COMPLETED'}}
                                    {{#if completed_at}} • Ολοκληρώθηκε: {{formatTime completed_at}}{{/if}}
                                {{/eq}}
                            </div>
                            <div class="small fw-bold"><i class="bi bi-geo-alt-fill me-1"></i>Παράδοση σε:
                                {{address}}{{#if floor}} (Όροφος {{floor}}){{/if}}</div>
                            {{#if comments}}<div class="smaller text-muted mt-1"><i
                                    class="bi bi-chat-left-dots me-1"></i>{{comments}}</div>{{/if}}
                        </div>
                        <div class="text-end">
                            <span
                                class="badge {{#eq status 'CANCELLED'}}bg-danger{{else}}bg-info{{/eq}} px-3 py-2 rounded-pill">
                                {{status}}
                            </span>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 border-top">
                    {{#unless (eq status 'CANCELLED')}}
                    {{!-- Progress Tracker --}}
                    <div class="order-tracker mb-5 mt-2 position-relative">
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-success" role="progressbar"
                                style="width: {{#eq status 'PENDING'}}10%{{/eq}}{{#eq status 'PREPARING'}}35%{{/eq}}{{#eq status 'READY'}}60%{{/eq}}{{#eq status 'DELIVERING'}}85%{{/eq}}{{#eq status 'COMPLETED'}}100%{{/eq}};">
                            </div>
                        </div>
                        <div class="d-flex justify-content-between mt-3 small fw-bold text-muted">
                            <div class="{{#eq status 'PENDING'}}text-success{{/eq}} text-center" style="width: 20%;">
                                <i class="bi bi-clock d-block h4"></i>
                                <span>Εκκρεμεί</span>
                            </div>
                            <div class="{{#eq status 'PREPARING'}}text-success{{/eq}} text-center" style="width: 20%;">
                                <i class="bi bi-egg-fried d-block h4"></i>
                                <span>Προετοιμασία</span>
                            </div>
                            <div class="{{#eq status 'READY'}}text-success{{/eq}} text-center" style="width: 20%;">
                                <i class="bi bi-box-seam d-block h4"></i>
                                <span>Έτοιμη</span>
                            </div>
                            <div class="{{#eq status 'DELIVERING'}}text-success{{/eq}} text-center" style="width: 20%;">
                                <i class="bi bi-bicycle d-block h4"></i>
                                <span>Καθ' οδόν</span>
                            </div>
                            <div class="{{#eq status 'COMPLETED'}}text-success{{/eq}} text-center" style="width: 20%;">
                                <i class="bi bi-check2-circle d-block h4"></i>
                                <span>Παραδόθηκε</span>
                            </div>
                        </div>
                    </div>
                    {{/unless}}

                    <div class="row mt-4">
                        <div class="col-md-7">
                            <h6 class="fw-bold mb-3">Προϊόντα</h6>
                            <ul class="list-group list-group-flush">
                                {{#each items}}
                                <li
                                    class="list-group-item bg-transparent px-0 py-2 border-0 d-flex justify-content-between align-items-center">
                                    <span>
                                        <span class="badge bg-light text-dark border me-2">{{quantity}}x</span>
                                        {{productName}}
                                    </span>
                                    <span class="text-muted">{{formatPrice price}}</span>
                                </li>
                                {{/each}}
                            </ul>
                        </div>
                        <div class="col-md-5 border-start">
                            <div class="ps-md-4 mt-3 mt-md-0">
                                {{#if (eq status 'COMPLETED')}}
                                <div class="mb-4 p-3 bg-light rounded-3 text-center border">
                                    <h6 class="fw-bold mb-2">Βαθμολογήστε την παραγγελία</h6>
                                    {{#if rating}}
                                    <div class="text-warning h4 mb-0">
                                        {{#repeat 5}}
                                        <i class="bi {{#if (le @index (subtract (roundStars ../rating) 1))}}bi-star-fill{{else}}bi-star{{/if}}"></i>
                                        {{/repeat}}
                                    </div>
                                    <div class="small text-muted mt-1">Η βαθμολογία σας: {{rating}}/5</div>
                                    {{else}}
                                    <form action="/orders/{{id}}/rate" method="POST" class="rating-form">
                                        <div class="d-flex justify-content-center gap-2 mb-2 h3 rating-stars">
                                            <i class="bi bi-star cursor-pointer star-btn" data-value="1"></i>
                                            <i class="bi bi-star cursor-pointer star-btn" data-value="2"></i>
                                            <i class="bi bi-star cursor-pointer star-btn" data-value="3"></i>
                                            <i class="bi bi-star cursor-pointer star-btn" data-value="4"></i>
                                            <i class="bi bi-star cursor-pointer star-btn" data-value="5"></i>
                                        </div>
                                        <input type="hidden" name="rating" id="rating-input-{{id}}" required>
                                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold shadow-sm d-none" id="submit-rating-{{id}}">Υποβολή</button>
                                    </form>
                                    {{/if}}
                                </div>
                                {{/if}}

                                <h6 class="fw-bold mb-3">Σύνοψη</h6>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Υποσύνολο</span>
                                    <span class="small">{{formatPrice total}}</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted small">Μεταφορικά</span>
                                    <span class="small">1,00 €</span>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold">Σύνολο</span>
                                    <span class="h5 fw-bold text-danger mb-0">{{formatPrice (add total 1)}}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}
            {{else}}
            <div class="text-center py-5">
                <div class="display-1 mb-4">📜</div>
                <h3 class="fw-bold">Δεν έχετε παραγγελίες ακόμα</h3>
                <p class="text-muted mb-4">Πραγματοποιήστε την πρώτη σας παραγγελία και θα εμφανιστεί εδώ!</p>
                <a href="/browse" class="btn btn-custom px-5 py-3 fw-bold shadow-sm">Πάμε για Φαγητό!</a>
            </div>
            {{/if}}
        </div>
    </div>
</main>